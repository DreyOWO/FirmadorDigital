root = true

[*]
end_of_line = lf
insert_final_newline = true

[*.md]
charset = utf-8
trim_trailing_whitespace = false

[{pom.xml,Jenkinsfile}]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.java]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[/src/main/resources/*messages*.properties]
charset = latin1
trim_trailing_whitespace = true

[/src/main/resources/xslt/html/simple-report.xslt]
charset = utf-8
indent_style = tab
trim_trailing_whitespace = true
